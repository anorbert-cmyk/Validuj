APP_NAME=Validuj
APP_BASE_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:3000
APP_ENV=development
DATABASE_PATH=/workspace/data/validuj.sqlite3
AUTH_SECRET=replace-me
ADMIN_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional remote model routing
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_RESEARCH_MODEL=perplexity/sonar-pro
OPENROUTER_REASONING_MODEL=anthropic/claude-3.7-sonnet
OPENROUTER_DESIGN_MODEL=openai/gpt-4.1

# Optional search provider
TAVILY_API_KEY=

# Deterministic local fallback engine label
LOCAL_MODEL_ID=local-synthesis-engine
